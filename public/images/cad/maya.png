le.","FLEX_REPORTING":"Reporting for Flex","FLEX_TOKEN_RATE":"Flex token rates","FOCUS":"Focus","FORMAT":"Format","FREQUENCY":"Frequency","FREQUENT_COMMAND_USAGE":"Your top {{ numCommand }} command categories in the past {{ numDays }} days","FREQUENT_COMMAND_USAGE_DESCRIPTION":"Common, occasional, and rare are grouped by how frequently they are used by {{ product }} users.","FREQUENT_USED":"Frequently used","GENERIC_ERROR_MESSAGE":"Your products are not included in reporting.","GENERIC_ERROR_MESSAGE_EXPORT":"There is nothing to export because your products are not included in reporting.","GOT_IT":"Got it","GO_SETTINGS":"Go to settings","GROUP":"Group","GROUP_FILTER_PLACEHOLDER":"Search for a group","GROUPS":"Groups","GROUPS_COLUMN_SELECTOR_FLYOUT":"Groups have been added as a new column.","GROUPS_FILTER_FLYOUT":"You can also filter to a specific Group.","HOURS_FORMAT":"h","HOURLY_DATA_EXPLANATORY_MODAL_INTRO":"View how many hours users access a product and their weekly average to help you optimize seat and token assignments.","HOURLY_DATA_EXPLANATORY_MODAL_TITLE":"Hourly data for desktop products is available with Premium plans","HOURLY_DATA_EXPLANATORY_MODAL_PROCESSING_TIME":"Hourly data might be delayed up to 24 hours. It is unavailable before {{ startTime }}, and for some products and versions.","HOURLY_DATA_EXPLANATORY_MODAL_MORE_PRODUCTS":"We’re adding hourly data to more products and cloud services over time.","HOURLY_DATA_UNAVAILABLE_TOOLTIP":"Hourly data is unavailable for this product or version.","HOURLY_DATA_PERMISSION_TOOLTIP":"Hourly data is only available for teams with a Premium plan.","HOURS_USED":"Hours used","HOURS_USED_TOOLTIP":"The number of hours a user accesses a product in the selected date range. Hourly data is unavailable for some products and versions.","HOVER":"Hover","INACTIVE":"Inactive","INACTIVE_USER":"Inactive user","INACTIVE_USERS":"Inactive users","INACTIVE_USER_INSIGHTS":"Inactive users haven\'t accessed at least one assigned product in 3 months or more. Unused products appear in user details.","INACTIVE_USER_MESSAGE":"A user is considered inactive if a product assigned to them has not been used in the last","INACTIVE_USER_MESSAGE_TIME":"A user is considered inactive if a product assigned to them has not been used in the last 3 months.","INACTIVE_USER_MESSAGE_TIME_V2":"A user is considered inactive if a product has not been used in the last {{number_of_months}} months and the user was assigned to that product during the entire selected period.","INACTIVE_USER_MESSAGE_TIME_30_DAYS":"A user is considered inactive if a product has not been used in the past 30 days and the user was assigned to that product during the entire selected period.","INACTIVE_USER_MESSAGE_TIME_X_MONTHS":"A user is considered inactive if a product has not been used in the past {{ X }} months and the user was assigned to that product during the entire selected period.","INCLUDE_DATA_COLUMNS":"Include data columns","INCLUDE_PII":"Include personal identifiable information including user names and email addresses.","INFO_ICON_TOOLTIP_COMMANDS_USED":"Commands used out of all the commands in this category.","INFO_ICON_TOOLTIP_FREQUENTLY_USED":"Frequently used commands among {{ product }} users.","INFO_ICON_TOOLTIP_INFREQUENTLY_USED":"Infrequently used commands among AutoCAD users, typically used in specialized workflows.","INFO_ICON_TOOLTIP_PERCENT_USE":"Percentage of use out of all the categories you’ve used.","INFO_ICON_TOOLTIP_PERIODICALLY_USED":"Periodically used commands among AutoCAD users.","INSIGHTS":"Insights","INSIGHTS_ONBOARDING_MSG":"Follow team trends with insights","INSIGHTS_ONBOARDING_MSG_DESCRIPTION":"Learn about how your teams work and identify potential improvement areas.","INSIGHT_FEEDBACK_HELPFUL":"Is this insight helpful?","INSIGHT_FEEDBACK_THANKS":"Thanks for your feedback","INSIGHTS_HELP":"Insights Help","INSIGHT_OTHER_COMMENT":"Do you have other comments you want to share with us?","INSIGHT_SAMPLE_MESSAGE":"Here are just a few examples of the insights you could receive: ","INSIGHT_TOOLTIP_HELPFUL":"This insight is helpful","INSIGHT_TOOLTIP_NOT_HELPFUL":"This insight is not helpful","INSIGHT_FEEDBACK_POSITIVE_PROMPT":"Can you tell us a bit more about your answer?","INSIGHT_FEEDBACK_OPTION_POSITIVE_NEW_INFO":"I learned something new.","INSIGHT_FEEDBACK_OPTION_POSITIVE_HELPS_LEARN_FASTER":"This information helped me learn faster.","INSIGHT_FEEDBACK_OPTION_POSITIVE_HELPS_WORK_EFFICIENTLY":"This information helped me work more efficiently.","INSIGHT_FEEDBACK_OPTION_POSITIVE_RELEVANT":"This information is relevant to my work.","INSIGHT_FEEDBACK_OPTION_POSITIVE_OTHER":"Something else.","INSIGHT_FEEDBACK_OPTION_NEGATIVE_NOT_RELEVANT":"The information is not relevant to what I’m doing. ","INSIGHT_FEEDBACK_OPTION_NEGATIVE_DIFFICULT_TO_UNDERSTAND":"The information is difficult to understand.","INSIGHT_FEEDBACK_OPTION_NEGATIVE_INFO_TOO_ADVANCED":"The information is too advanced for me.","INSIGHT_FEEDBACK_OPTION_NEGATIVE_ALREADY_SEEN":"I’ve already seen this information before.","INSIGHT_FEEDBACK_OPTION_NEGATIVE_OTHER":"Something else.","ITEMS":"items","LAST":"Last","LAST_ACCESSED":"Last accessed","LAST_ACCESS_PRODUCT":"last access to this product was at least 3 months ago:","LAST_ACCESS_TO_PRODUCT":"Last access was at least 3 months ago","LAST_ACCESS_WAS_AT":"Last access was at least 3 months ago","LATEST_USAGE":"Data last processed on","LEARN_ABOUT_MY_INSIGHTS":"Learn about My Insights","LEARN_INSIGHTS":"Learn about how you work and take full advantage of the products you use.","LEARN_MORE":"Learn more","LEARN_MORE_INSIGHTS":"Learn more about insights","LEARN_MORE_v2":"<0>Learn more</0> about product usage reporting.","LEARN_MORE_TEAM":"Learn more about team insights.","LEARN_MORE_TXT":"about using reporting to make decisions based on data, not instinct.","LEARN_MORE_TXT_v2":"about product usage reporting.","MACHINE_NAME":"Machine Name","MACHINE_NAMEV2":"Machine name","MANAGE