e}}.","BULK_ASSIGN_NON_MANAGEABLE_SUCCESS_NO_FEATURES":"These users will be assigned {{productName}}.","BULK_ASSIGN_NON_MANAGEABLE_SUCCESS_plural":"These users will be assigned {{productName}}, which comes with {{totalCount}} products and services.","BULK_ASSIGN_BACK_BUTTON":"Back","BULK_ASSIGN_ERROR_DIALOGUE":"This user won\'t be assigned unless you fix the error in the log and upload the CSV file again.","BULK_ASSIGN_ERROR_DIALOGUE_plural":"These users won\'t be assigned unless you fix the errors in the log and upload the CSV file again.","BULK_ASSIGN_FILE_LIMIT":"A CSV file can contain up to 5,000 users. You\'ll need to upload multiple files to invite and assign all users.","BULK_ASSIGN_SEAT_LIMIT":"The CSV file contains {{totalInvites}} users and only {{seatsAvailable}} seats are available. To free up seats, unassign users or buy more seats.","BULK_ASSIGN_SEAT_LIMIT_DIALOGUE":"There aren’t enough seats available","BULK_ASSIGN_USER_NETWORK_HEADER":"Network problems","BULK_ASSIGN_USER_NETWORK_ERROR":"Check your connection then click Upload. If the problem continues, contact support.","BULK_ASSIGN_NETWORK_ERROR":"{{totalCount}} users weren\'t assigned due to network problems.","BULK_ASSIGN_NETWORK_ERROR_single":"{{count}} user wasn\'t assigned due to network problems.","USERS":"users","USER_LIST_SEARCH_COUNT_HEADING":"{{userCount}} user for {{searchText}}","USER_LIST_SEARCH_COUNT_HEADING_plural":"{{userCount}} users for {{searchText}}","UNASSIGN_ALL_ITEMS":"Unassign all items","EXTENDED_OFFLINE":"Extended offline","NEW":"New","TEAMS_ACTIONS_MENU":"Actions","TEAMS_GROUP_CREATE":"create","TEAMS_GROUP_UPDATE":"update","TEAMS_GROUP_DELETE":"delete","TEAMS_ACTIONS_MENU_CREATE_TEAM":"Create team","CREATE":"Create","BANNER_TEAM_CREATED_SUCCESS":"{{teamName}} team has been successfully created.","BANNER_TEAM_CREATED_ERROR":"An error occurred. Click Create again.","TEAMS_ACTIONS_MENU_MOVE_SUBSCRIPTIONS_TO_THIS_TEAM":"Move subscriptions to this team","TEAMS_CREATE_TEAM_MODAL